{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "tls",
        "tag": "dns-remote",
        "server": "1.1.1.1",
        "detour": "@@RESI_NODE_NAME@@"
      },
      {
        "type": "udp",
        "tag": "dns-direct",
        "server": "223.5.5.5"
      },
      {
        "type": "udp",
        "tag": "dns-direct-backup",
        "server": "119.29.29.29"
      }
    ],
    "rules": [
      {
        "rule_set": "geosite-category-ads-all",
        "action": "reject"
      },
      {
        "rule_set": "geosite-cn",
        "server": "dns-direct"
      }
    ],
    "final": "dns-remote",
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    }
  ],
  "outbounds": [
    {
      "type": "anytls",
      "tag": "@@RESI_NODE_NAME@@",
      "server": "@@RESI_SERVER_IP@@",
      "server_port": @@RESI_INBOUND_PORT@@,
      "password": "@@RESI_ANYTLS_PASSWORD@@",
      "idle_session_check_interval": "30s",
      "idle_session_timeout": "30s",
      "min_idle_session": 5,
      "tls": {
        "enabled": true,
        "server_name": "@@RESI_SNI@@",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "@@RESI_REALITY_PUBLIC_KEY@@",
          "short_id": "@@RESI_SHORT_ID@@"
        }
      }
    },
    {
      "type": "anytls",
      "tag": "@@DC_NODE_NAME@@",
      "server": "@@DC_SERVER_IP@@",
      "server_port": @@DC_INBOUND_PORT@@,
      "password": "@@DC_ANYTLS_PASSWORD@@",
      "idle_session_check_interval": "30s",
      "idle_session_timeout": "30s",
      "min_idle_session": 5,
      "tls": {
        "enabled": true,
        "server_name": "@@DC_SNI@@",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "@@DC_REALITY_PUBLIC_KEY@@",
          "short_id": "@@DC_SHORT_ID@@"
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs",
        "download_detour": "@@RESI_NODE_NAME@@",
        "update_interval": "7d"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "download_detour": "@@RESI_NODE_NAME@@",
        "update_interval": "7d"
      },
      {
        "type": "remote",
        "tag": "geosite-category-ads-all",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ads-all.srs",
        "download_detour": "@@RESI_NODE_NAME@@",
        "update_interval": "7d"
      }
    ],
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "outbound": "direct" },
      { "rule_set": "geosite-category-ads-all", "action": "reject" },
      {
        "domain_suffix": [
          "12306.cn",
          "126.com",
          "163.com",
          "36kr.com",
          "abchina.com",
          "alicdn.com",
          "alipay.com",
          "aliyun.com",
          "aliyuncs.com",
          "amap.com",
          "autonavi.com",
          "baidu.com",
          "baiducontent.com",
          "bankcomm.com",
          "bankofchina.com",
          "bdstatic.com",
          "bilibili.com",
          "biligame.com",
          "ccb.com",
          "com.cn",
          "csdn.net",
          "ctrip.com",
          "dianping.com",
          "didiglobal.com",
          "dingtalk.com",
          "douban.com",
          "douyin.com",
          "edu.cn",
          "ele.me",
          "feishu.cn",
          "gov.cn",
          "huxiu.com",
          "icbc.com.cn",
          "iqiyi.com",
          "ixigua.com",
          "jd.com",
          "jdpay.com",
          "kuaishou.com",
          "larksuite.com",
          "lianjia.com",
          "mafengwo.cn",
          "meituan.com",
          "org.cn",
          "pinduoduo.com",
          "qq.com",
          "qunar.com",
          "sankuai.com",
          "sina.com.cn",
          "sinaimg.cn",
          "taobao.com",
          "tencent.com",
          "tmall.com",
          "toutiao.com",
          "wechat.com",
          "weibo.com",
          "xiaohongshu.com",
          "ximalaya.com",
          "xueqiu.com",
          "youku.com",
          "zhihu.com",
          "zhipin.com"
        ],
        "outbound": "direct"
      },
      { "rule_set": "geosite-cn", "outbound": "direct" },
      { "rule_set": "geoip-cn", "outbound": "direct" },
      {
        "domain_suffix": [
          "openai.com",
          "chatgpt.com",
          "oaistatic.com",
          "oaiusercontent.com",
          "anthropic.com",
          "claude.ai",
          "googleapis.com",
          "gemini.google.com",
          "bard.google.com",
          "netflix.com",
          "nflxvideo.net"
        ],
        "outbound": "@@RESI_NODE_NAME@@"
      },
      {
        "domain_suffix": [
          "telegram.org",
          "t.me",
          "telegram.me",
          "tdesktop.com",
          "telesco.pe",
          "cdn-telegram.org",
          "discord.com",
          "discord.gg",
          "discordapp.com",
          "discordapp.net",
          "discord.media"
        ],
        "outbound": "@@DC_NODE_NAME@@"
      },
      {
        "ip_cidr": [
          "91.108.4.0/22",
          "91.108.8.0/22",
          "91.108.12.0/22",
          "91.108.16.0/22",
          "91.108.20.0/22",
          "91.108.56.0/22",
          "149.154.160.0/20"
        ],
        "outbound": "@@DC_NODE_NAME@@"
      },
      { "network": "udp", "port": 443, "action": "reject" }
    ],
    "final": "@@RESI_NODE_NAME@@",
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-direct"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_rdrc": true
    }
  }
}
